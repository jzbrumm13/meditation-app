# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native — signing keys and certificates. Never commit any of these.
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
AuthKey_*.p8

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Claude Code local workspace configs (per-machine, not part of source)
.claude/

# Archive of the abandoned Expo-v1 experiments (kept locally for reference only)
.old-expo/

# Old/experimental artifacts not part of the shipping app
showcase.html
nondual-10min-v1.mp3
*.zip

# Audio build artifacts — outputs are regenerable from clips + build scripts.
# Source clips are kept in git (audio-build/clips/) so anyone can rebuild
# the meditations end-to-end. Final mp3s live in Supabase, not the repo.
audio-build/output/
